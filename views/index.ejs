    <button
      id="scroll-to-top"
      class="scroll-to-top"
      onclick="scrollToTop()"
      aria-label="Scroll to top"
    >
      ↑
    </button>

    <script>
      function openInstructorPanel() {
        const panel = document.getElementById("instructor-panel");
        panel.classList.add("show");
        panel.setAttribute("aria-hidden", "false");
        document.body.classList.add("instructor-open");
      }

      function closeInstructorPanel() {
        const panel = document.getElementById("instructor-panel");
        panel.classList.remove("show");
        panel.setAttribute("aria-hidden", "true");
        document.body.classList.remove("instructor-open");
      }

      function scrollToTop() {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      // Show/hide scroll-to-top button
      window.addEventListener("scroll", () => {
        const scrollBtn = document.getElementById("scroll-to-top");
        if (window.scrollY > 300) {
          scrollBtn.classList.add("show");
        } else {
          scrollBtn.classList.remove("show");
        }
      });

      // Launchpad card toggle for mobile
      const launchpadToggles = document.querySelectorAll(".launchpad-toggle");
      launchpadToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          // Only toggle on mobile (768px and below)
          if (window.innerWidth <= 768) {
            const card = toggle.closest(".launchpad-collapsible");
            const isCollapsed = card.classList.toggle("collapsed");
            toggle.setAttribute("aria-expanded", !isCollapsed);
          }
        });
      });

      // Keep mini pill in sync with available seats
      function updateFormSeatDisplay() {
        const seatsAvailable =
          document.getElementById("seat-count").textContent;
        document.getElementById("form-seat-inline").textContent =
          `${seatsAvailable} seat${seatsAvailable === "1" ? "" : "s"} left`;
      }

      // Observe changes to seat count and update form display
      const seatCountEl = document.getElementById("seat-count");
      const observer = new MutationObserver(() => {
        updateFormSeatDisplay();
      });
      observer.observe(seatCountEl, {
        childList: true,
        characterData: true,
        subtree: true,
      });

      // ── Registration handler ─────────────────────────────────────────────
      async function handleRegister() {
        const fname = document.getElementById("fname").value.trim();
        const lname = document.getElementById("lname").value.trim();
        const email = document.getElementById("email").value.trim();
        const err = document.getElementById("error-banner");
        const success = document.getElementById("success-banner");

        err.classList.remove("show");
        success.classList.remove("show");

        if (!fname || !lname || !email) {
          err.textContent = "Please fill in all required fields.";
          err.classList.add("show");
          return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          err.textContent = "Please enter a valid email address.";
          err.classList.add("show");
          return;
        }

        const btn = document.getElementById("register-btn");
        btn.disabled = true;
        btn.textContent = "Redirecting to Stripe…";

        try {
          // Store user info in sessionStorage for after payment
          sessionStorage.setItem(
            "registration_data",
            JSON.stringify({ fname, lname, email }),
          );

          // Build return URL with payment success parameter
          const returnUrl = `${window.location.origin}${window.location.pathname}?payment_success=true&email=${encodeURIComponent(email)}`;

          // Redirect to Stripe Payment Link with prefilled email
          const stripeUrl = `https://buy.stripe.com/test_00wcN44LM0eU5CC2wNcbC00?client_reference_id=${encodeURIComponent(email)}&prefilled_email=${encodeURIComponent(email)}`;

          // Redirect to Stripe
          window.location.href = stripeUrl;
        } catch (e) {
          err.textContent = "Something went wrong. Please try again.";
          err.classList.add("show");
          btn.disabled = false;
          btn.textContent = "Claim My Seat — $100 CAD";
          console.error(e);
        }
      }
    </script>
