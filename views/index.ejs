<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project Management Masterclass</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header>
      <div class="logo">PM Career Masterclass</div>
      <div class="nav-actions">
        <button class="nav-ghost" onclick="openInstructorPanel()">
          Meet your instructor
        </button>
        <button
          class="nav-cta"
          onclick="
            document
              .getElementById('register')
              .scrollIntoView({ behavior: 'smooth' })
          "
        >
          Reserve My Spot Now
        </button>
      </div>
    </header>

    <section class="instructor-panel" id="instructor-panel" aria-hidden="true">
      <div class="instructor-inner">
        <div class="instructor-topbar">
          <p class="instructor-kicker">Meet Your Instructor</p>
          <button class="instructor-close" onclick="closeInstructorPanel()">
            Back to class page
          </button>
        </div>

        <h2 class="instructor-title">
          Learn From Someone Who Started Exactly Where You Are
        </h2>

        <div class="instructor-copy">
          <p>
            PM Launchpad is taught by Ogaga Johnson, an award-winning Project
            Management Executive and educator.
          </p>
          <p>
            Ogaga did not begin her career as a senior project manager. She
            started as a Project Coordinator intern, learning the fundamentals
            and building her experience step by step.
          </p>
          <p>
            Today, she has built a successful career in project management
            spanning three continents: Africa, Europe, and North America.
          </p>
          <p>She is now a:</p>
          <ul>
            <li>Project Management Executive</li>
            <li>Speaker and educator</li>
            <li>
              Career mentor helping professionals transition into project
              management, and has helped over 20,000 professionals.
            </li>
          </ul>
          <p>
            Through her work and her widely followed YouTube channel, Ogaga has
            helped thousands of professionals gain clarity about careers in
            project management.
          </p>
          <p>
            PM Launchpad is her way of helping beginners take that first
            confident step.
          </p>
          <p>
            Because starting a new career path is easier when you do not have to
            figure it out alone.
          </p>
        </div>
      </div>
    </section>

    <section class="hero">
      <div class="hero-left">
        <p class="eyebrow">Live Online Masterclass · 3 Hours</p>
        <h1>
          Before You Spend Thousands on Certifications,<br />
          Spend <em>3 Hours</em> Understanding Project Management.
        </h1>
        <p class="hero-desc">
          In this 3-hour live masterclass, award-winning Project Management
          Executive,
          <span class="speaker-name">Ogaga Johnson</span>
          will walk you through the foundations of project management, the
          skills it requires, and how people from different backgrounds break
          into the field.
        </p>
        <div class="hero-actions">
          <a href="#register" class="btn-primary">Reserve My Spot Now</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="seat-card">
          <p class="seat-label">Live Class Seats Remaining</p>
          <div class="seat-number" id="seat-count"><%= seats.available %></div>
          <p class="seat-sub">
            of <span id="total-seats"><%= seats.total %></span> total
          </p>
        </div>
      </div>
    </section>

    <section class="story">
      <div class="story-wrap">
        <p class="story-lead">
          You have been thinking about Project Management for a while. You have
          spent weeks researching it.
        </p>
        <p>
          You have seen titles like Project Manager, Project Coordinator, and
          Program Manager. You have heard it is a strong career path with
          opportunities across industries.
        </p>
        <p>
          So you started with a quick search: "How do I become a Project
          Manager?" "What is Project Management about?" Then came 14 tabs,
          half-finished courses, and more confusion than clarity.
        </p>
      </div>
    </section>

    <section class="details">
      <div class="details-grid">
        <article class="card card-dark">
          <h3>You Have Seen the Roles</h3>
          <ul>
            <li>Project Manager</li>
            <li>Project Coordinator</li>
            <li>Program Manager</li>
          </ul>
        </article>
        <article class="card card-light">
          <h3>What Leaves Most People Stuck</h3>
          <p>
            PMP certifications, Agile frameworks, Scrum methodologies, Waterfall
            planning, and tools you have never heard of.
          </p>
          <p>Most beginners do not fail because they lack ability.</p>
          <p>They fail because they start backwards.</p>
        </article>
        <article class="card card-accent">
          <h3>Questions This Masterclass Clears Up</h3>
          <ul>
            <li>Where do you even start?</li>
            <li>Do you need technical skills?</li>
            <li>Do you need a certification first?</li>
            <li>Do companies even hire beginners?</li>
          </ul>
        </article>
      </div>
    </section>

    <section class="launchpad">
      <div class="launchpad-intro">
        <p>
          They jump straight into certifications, tools, and complex frameworks
          without first understanding the big picture.
        </p>
        <p>
          What Project Management actually is. How projects really work. And how
          people enter the field in the first place.
        </p>
        <p>
          That is exactly what this class is designed to help you understand.
        </p>
      </div>

      <div class="launchpad-panel">
        <h2>PM Launchpad: Your First Step into Project Management</h2>
        <p class="launchpad-sub">
          PM Launchpad is a 3-hour Introductory Masterclass designed for people
          like you who want to understand project management before committing
          to certifications or full training programs.
        </p>

        <div class="launchpad-grid">
          <article class="launchpad-card">
            <h3>In this masterclass, you will learn:</h3>
            <ul>
              <li>What project management really is and why it matters</li>
              <li>The 5 phases of the project lifecycle</li>
              <li>
                The difference between Agile, Waterfall, and Hybrid project
                approaches
              </li>
              <li>The key tools project managers use to organise work</li>
              <li>How projects are planned, executed, and delivered</li>
              <li>
                How people from different backgrounds transition into project
                management
              </li>
            </ul>
          </article>

          <article class="launchpad-card launchpad-card-accent">
            <p class="launchpad-note">This is not a theory-heavy lecture.</p>
            <p>
              It is a structured introduction designed to give you the clarity
              most people spend months trying to piece together.
            </p>
            <p>
              While most introductions to project management stop at
              explanations, PM Launchpad goes a step further.
            </p>
            <p>
              During the session, you will participate in a simulated project
              exercise where you will practice thinking like a project manager.
            </p>
            <p>
              By the end of the class, you won't just understand project
              management conceptually, you'll have experienced how it works.
            </p>

            <h3>You will learn how to:</h3>
            <ul>
              <li>Define a project objective</li>
              <li>Identify key stakeholders</li>
              <li>Outline project scope</li>
              <li>Break work into manageable steps</li>
              <li>Identify potential risks</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section id="register">
      <div class="register-left">
        <h2>
          Get Clarity Before You Commit<br /><em>Your Time and Money.</em>
        </h2>
        <p>
          This session simplifies project management so you can take your first
          confident steps, no matter your background.
        </p>

        <div class="price-tag">
          <span class="price-currency">$</span>
          <span class="price-amount">50</span>
          <span class="price-period">CAD / one-time</span>
        </div>

        <ul class="perks">
          <li>Understand what project management really involves</li>
          <li>Learn the core skills employers actually value</li>
          <li>Get a beginner-friendly path into the profession</li>
          <li>Know your next 30 days after the class</li>
        </ul>
      </div>

      <div class="register-form">
        <p class="form-title">Reserve Your Seat</p>
        <p class="form-subtitle">
          Complete the form below to lock in your spot for the live class.
        </p>

        <div class="mini-seat-pill">
          <span class="dot"></span>
          <span id="form-seat-inline"><%= seats.available %> seats left</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" id="fname" placeholder="First Name" />
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" id="lname" placeholder="Last Name" />
          </div>
        </div>

        <div class="form-group">
          <label>Email Address</label>
          <input type="email" id="email" placeholder="Email Address" />
        </div>

        <div class="form-group">
          <label>How did you hear about us?</label>
          <select id="referral" style="color: #888">
            <option value="" disabled selected>Select one…</option>
            <option>Social media</option>
            <option>Friend / colleague</option>
            <option>Search engine</option>
            <option>Newsletter</option>
            <option>Other</option>
          </select>
        </div>

        <button id="register-btn" onclick="handleRegister()">
          Reserve My Spot Now — $50 CAD
        </button>

        <div class="error-banner" id="error-banner"></div>
        <div class="success-banner" id="success-banner">
          🎉 You're in! Check your email for next steps and payment details.
        </div>

        <p class="form-note">🔒 Secure & encrypted</p>
      </div>
    </section>

    <footer>
      <p>© 2026 PM Career Masterclass. All rights reserved.</p>
      <p>
        <a href="#">Privacy Policy</a> · <a href="#">Terms</a> ·
        <a href="mailto:hello@example.com">hello@example.com</a>
      </p>
    </footer>

    <script>
      function openInstructorPanel() {
        const panel = document.getElementById("instructor-panel");
        panel.classList.add("show");
        panel.setAttribute("aria-hidden", "false");
        document.body.classList.add("instructor-open");
      }

      function closeInstructorPanel() {
        const panel = document.getElementById("instructor-panel");
        panel.classList.remove("show");
        panel.setAttribute("aria-hidden", "true");
        document.body.classList.remove("instructor-open");
      }

      // Keep mini pill in sync with available seats
      function updateFormSeatDisplay() {
        const seatsAvailable =
          document.getElementById("seat-count").textContent;
        document.getElementById("form-seat-inline").textContent =
          `${seatsAvailable} seat${seatsAvailable === "1" ? "" : "s"} left`;
      }

      // Observe changes to seat count and update form display
      const seatCountEl = document.getElementById("seat-count");
      const observer = new MutationObserver(() => {
        updateFormSeatDisplay();
      });
      observer.observe(seatCountEl, {
        childList: true,
        characterData: true,
        subtree: true,
      });

      // ── Registration handler ─────────────────────────────────────────────
      async function handleRegister() {
        const fname = document.getElementById("fname").value.trim();
        const lname = document.getElementById("lname").value.trim();
        const email = document.getElementById("email").value.trim();
        const err = document.getElementById("error-banner");
        const success = document.getElementById("success-banner");

        err.classList.remove("show");
        success.classList.remove("show");

        if (!fname || !lname || !email) {
          err.textContent = "Please fill in all required fields.";
          err.classList.add("show");
          return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          err.textContent = "Please enter a valid email address.";
          err.classList.add("show");
          return;
        }

        const btn = document.getElementById("register-btn");
        btn.disabled = true;
        btn.textContent = "Redirecting to Stripe…";

        try {
          // Store user info in sessionStorage for after payment
          sessionStorage.setItem(
            "registration_data",
            JSON.stringify({ fname, lname, email }),
          );

          // Build return URL with payment success parameter
          const returnUrl = `${window.location.origin}${window.location.pathname}?payment_success=true&email=${encodeURIComponent(email)}`;

          // Redirect to Stripe Payment Link with prefilled email
          const stripeUrl = `https://buy.stripe.com/test_00wcN44LM0eU5CC2wNcbC00?client_reference_id=${encodeURIComponent(email)}&prefilled_email=${encodeURIComponent(email)}`;

          // Redirect to Stripe
          window.location.href = stripeUrl;
        } catch (e) {
          err.textContent = "Something went wrong. Please try again.";
          err.classList.add("show");
          btn.disabled = false;
          btn.textContent = "Claim My Seat — $100 CAD";
          console.error(e);
        }
      }
    </script>
  </body>
</html>
