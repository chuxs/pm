<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Masterclass — Limited Seats</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <!-- ── HEADER ── -->
    <header>
      <div class="logo">The Masterclass</div>
      <button
        class="nav-cta"
        onclick="
          document
            .getElementById('register')
            .scrollIntoView({ behavior: 'smooth' })
        "
      >
        Reserve Your Seat
      </button>
    </header>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="hero-left">
        <p class="eyebrow">Spring Cohort · 2025 · Intensive</p>
        <h1>
          Build the skills<br />that <em>actually</em><br />change careers.
        </h1>
        <p class="hero-desc">
          A hands-on 8-week workshop for professionals ready to level up. Small
          cohort. Real projects. Lifetime access to the community.
        </p>
        <div class="hero-actions">
          <a href="#register" class="btn-primary">Claim Your Spot</a>
          <button class="btn-secondary">Learn what's inside ↓</button>
        </div>
      </div>

      <div class="hero-right">
        <div class="seat-card">
          <p class="seat-label">Seats Remaining</p>
          <div class="seat-number" id="seat-count"><%= seats.available %></div>
          <p class="seat-sub">
            of <span id="total-seats"><%= seats.total %></span> total
          </p>
        </div>
      </div>
    </section>

    <!-- ── FEATURES ── -->
    <section class="features">
      <div class="feature-item" style="animation-delay: 0.1s">
        <div class="feature-icon">🎯</div>
        <h3 class="feature-title">Project-Based Learning</h3>
        <p class="feature-desc">
          Every week builds toward a portfolio piece you're proud to show. No
          fluff, no filler—only skills that matter.
        </p>
      </div>
      <div class="feature-item" style="animation-delay: 0.2s">
        <div class="feature-icon">🧑‍🏫</div>
        <h3 class="feature-title">Expert-Led Sessions</h3>
        <p class="feature-desc">
          Live workshops with industry practitioners. Ask questions, get
          feedback, and fast-track your growth with real mentors.
        </p>
      </div>
      <div class="feature-item" style="animation-delay: 0.3s">
        <div class="feature-icon">🤝</div>
        <h3 class="feature-title">Tight-Knit Cohort</h3>
        <p class="feature-desc">
          We cap enrollment intentionally. You'll know everyone by name, and
          they'll become your professional network for life.
        </p>
      </div>
    </section>

    <!-- ── REGISTRATION ── -->
    <section id="register">
      <div class="register-left">
        <h2>Reserve your<br /><em>seat today.</em></h2>
        <p>
          Spots fill up fast—this cohort has never reopened after selling out.
          Lock in your place before the countdown hits zero.
        </p>

        <div class="price-tag">
          <span class="price-currency">$</span>
          <span class="price-amount">50</span>
          <span class="price-period">CAD / one-time</span>
        </div>

      <div class="register-form">
        <p class="form-title">Join the Cohort</p>
        <p class="form-subtitle">
          Complete the form below to secure your spot.
        </p>

        <div class="mini-seat-pill">
          <span class="dot"></span>
          <span id="form-seat-inline"><%= seats.available %> seats left</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" id="fname" placeholder="Ada" />
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" id="lname" placeholder="Lovelace" />
          </div>
        </div>

        <div class="form-group">
          <label>Email Address</label>
          <input type="email" id="email" placeholder="ada@example.com" />
        </div>

        <div class="form-group">
          <label>How did you hear about us?</label>
          <select id="referral" style="color: #888">
            <option value="" disabled selected>Select one…</option>
            <option>Social media</option>
            <option>Friend / colleague</option>
            <option>Search engine</option>
            <option>Newsletter</option>
            <option>Other</option>
          </select>
        </div>

        <button id="register-btn" onclick="handleRegister()">
          Claim My Seat — $997
        </button>

        <div class="error-banner" id="error-banner"></div>
        <div class="success-banner" id="success-banner">
          🎉 You're in! Check your email for next steps and payment details.
        </div>

        <p class="form-note">
          🔒 Secure & encrypted · 30-day money-back guarantee
        </p>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer>
      <p>© 2025 The Masterclass. All rights reserved.</p>
      <p>
        <a href="#">Privacy Policy</a> · <a href="#">Terms</a> ·
        <a href="mailto:hello@example.com">hello@example.com</a>
      </p>
    </footer>

    <script>
      // Keep mini pill in sync with available seats
      function updateFormSeatDisplay() {
        const seatsAvailable =
          document.getElementById("seat-count").textContent;
        document.getElementById("form-seat-inline").textContent =
          `${seatsAvailable} seat${seatsAvailable === "1" ? "" : "s"} left`;
      }

      // Observe changes to seat count and update form display
      const seatCountEl = document.getElementById("seat-count");
      const observer = new MutationObserver(() => {
        updateFormSeatDisplay();
      });
      observer.observe(seatCountEl, {
        childList: true,
        characterData: true,
        subtree: true,
      });

      // ── Registration handler ─────────────────────────────────────────────
      async function handleRegister() {
        const fname = document.getElementById("fname").value.trim();
        const lname = document.getElementById("lname").value.trim();
        const email = document.getElementById("email").value.trim();
        const err = document.getElementById("error-banner");
        const success = document.getElementById("success-banner");

        err.classList.remove("show");
        success.classList.remove("show");

        if (!fname || !lname || !email) {
          err.textContent = "Please fill in all required fields.";
          err.classList.add("show");
          return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          err.textContent = "Please enter a valid email address.";
          err.classList.add("show");
          return;
        }

        const btn = document.getElementById("register-btn");
        btn.disabled = true;
        btn.textContent = "Redirecting to Stripe…";

        try {
          // Store user info in sessionStorage for after payment
          sessionStorage.setItem(
            "registration_data",
            JSON.stringify({ fname, lname, email }),
          );

          // Build return URL with payment success parameter
          const returnUrl = `${window.location.origin}${window.location.pathname}?payment_success=true&email=${encodeURIComponent(email)}`;

          // Redirect to Stripe Payment Link with prefilled email
          const stripeUrl = `https://buy.stripe.com/test_00wcN44LM0eU5CC2wNcbC00?client_reference_id=${encodeURIComponent(email)}&prefilled_email=${encodeURIComponent(email)}`;

          // Redirect to Stripe
          window.location.href = stripeUrl;
        } catch (e) {
          err.textContent = "Something went wrong. Please try again.";
          err.classList.add("show");
          btn.disabled = false;
          btn.textContent = "Claim My Seat — $997";
          console.error(e);
        }
      }
    </script>
  </body>
</html>
